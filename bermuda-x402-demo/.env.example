# Copy this file to .env.local and fill in the values.
#
# Quick-start:
#   1. Deploy MockUSDC.sol → paste address into NEXT_PUBLIC_USDC_ADDRESS
#   2. Get Base Sepolia ETH → paste private key into FACILITATOR_PK and FAUCET_PK
#   3. Generate a throwaway key → paste into NEXT_PUBLIC_AGENT_PK
#   4. npm run dev
#   5. Click "Top up" in the agent bar to mint tokens to the agent

NEXT_PUBLIC_NETWORK=baseSepolia
NEXT_PUBLIC_PAY_TO=0x0000000000000000000000000000000000000001
ORDER_SECRET=change-me-in-production

# MockUSDC (deploy from contracts/evm/script/DeployMockUSDC.s.sol)
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_USDC_NAME=USD Coin
NEXT_PUBLIC_USDC_VERSION=2

# Self-hosted facilitator
FACILITATOR_URL=http://localhost:3000/api/facilitator
FACILITATOR_PK=

# Faucet wallet — needs Base Sepolia ETH only (calls mint(), not transfer())
FAUCET_PK=

# Agent wallet — throwaway key, exposed client-side (testnet only)
NEXT_PUBLIC_AGENT_PK=

# Tx links in receipt + inspector (default: Base Sepolia Blockscout)
# NEXT_PUBLIC_EXPLORER_TX_URL=https://sepolia.basescan.org

# Optional: shared secret — if set, client must send X-Demo-Token (reduces public drain)
# NEXT_PUBLIC_DEMO_TOKEN=

# Ops: keep FAUCET_PK wallet topped up with Base Sepolia ETH; monitor agent USDC for long events
